# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/contract_system

# Auth
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Ethereum (only required when backend submits transactions)
RPC_URL=https://sepolia.infura.io/v3/your_project_id
PRIVATE_KEY=

# External services
PINATA_JWT=
GEMINI_API_KEY=
