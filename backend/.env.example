# Server
PORT=5000
HOST=0.0.0.0
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/contract_system

# Auth — must be at least 32 characters
JWT_SECRET=change_me_to_a_long_random_string_32_chars_or_more
JWT_EXPIRES_IN=7d

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173

# Ethereum (only required when backend submits transactions)
RPC_URL=https://sepolia.infura.io/v3/your_project_id
PRIVATE_KEY=

# External services
PINATA_JWT=
GEMINI_API_KEY=
